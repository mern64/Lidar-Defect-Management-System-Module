# ─────────────────────────────────────────────────────────────────
# PCD Application — Environment Configuration Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# Never commit .env to git!
# ─────────────────────────────────────────────────────────────────

# REQUIRED — Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# PostgreSQL Database URL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# When running with Docker Compose, host = flask_db (the service name)
DATABASE_URL=postgresql://pcd_user:pcd_password@flask_db:5432/pcd_db

# Flask environment: 'development' or 'production'
FLASK_ENV=development

# ─────────────────────────────────────────────────────────────────
# Email Notifications (Gmail SMTP)
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Create an App Password for "Mail" and paste it below
# ─────────────────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
NOTIFICATION_EMAILS=dev1@gmail.com,dev2@gmail.com
